# ── CORE ─────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── GUMROAD ───────────────────────────────────────────────────────────────────
# Get from: https://app.gumroad.com/settings/advanced → Access token
GUMROAD_ACCESS_TOKEN=your_gumroad_token_here
# Get from: your product URL — the ID after gumroad.com/l/
GUMROAD_PRODUCT_ID=your_product_id_here
GUMROAD_PRODUCT_URL=https://gumroad.com/l/YOUR_PRODUCT_ID

# ── REDDIT ────────────────────────────────────────────────────────────────────
# Get from: https://www.reddit.com/prefs/apps → Create app (script type)
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_SECRET=your_reddit_secret
REDDIT_USERNAME=your_reddit_username
REDDIT_PASSWORD=your_reddit_password

# ── LINKEDIN ─────────────────────────────────────────────────────────────────
# Get from: https://www.linkedin.com/developers/apps → create app → OAuth token
LINKEDIN_ACCESS_TOKEN=your_linkedin_token
# Your LinkedIn person URN — get from: https://api.linkedin.com/v2/userinfo
LINKEDIN_PERSON_URN=your_person_urn

# ── TWITTER / X ───────────────────────────────────────────────────────────────
# Get from: https://developer.twitter.com/en/portal/dashboard
TWITTER_API_KEY=your_api_key
TWITTER_API_SECRET=your_api_secret
TWITTER_ACCESS_TOKEN=your_access_token
TWITTER_ACCESS_SECRET=your_access_secret

# ── NEWSLETTER (Beehiiv — free plan works) ────────────────────────────────────
# Get from: https://app.beehiiv.com/settings/integrations
BEEHIIV_API_KEY=your_beehiiv_api_key
BEEHIIV_PUBLICATION_ID=your_publication_id

# ── HACKER NEWS ───────────────────────────────────────────────────────────────
# HN has no submission API — the agent logs into news.ycombinator.com with
# your credentials and submits the same DEV.to article URL every Monday.
# Account must have enough karma to submit (new accounts may be rate limited).
HN_USERNAME=your_hn_username
HN_PASSWORD=your_hn_password

# ── EMAIL REPORTS ─────────────────────────────────────────────────────────────
REPORT_EMAIL=your_personal_email@gmail.com
SMTP_EMAIL=your_sender_gmail@gmail.com
# Get from: Google Account → Security → App Passwords
SMTP_APP_PASSWORD=your_gmail_app_password
